<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Botty-verse — Live Hive</title>
<meta name="theme-color" content="#04140d" />
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌐</text></svg>" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&display=swap" rel="stylesheet" />
<style>
  :root{
    --rood:#b52718;
    --groen:#1a5c4a;
    --teal:#2f8f86;
    --matrix:#39ff85;
    --matrix-dim:#1f7d4d;
    --paneel:rgba(6,26,18,.78);
    --paneel-rand:#1c5b42;
    --licht:#dff7ea;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html,body{min-height:100vh;}
  body{
    font-family:'Nunito',sans-serif;
    background:#04140d;
    color:var(--licht);
    display:flex;flex-direction:column;align-items:center;
    padding:1.4rem 1rem 3rem;
    position:relative;overflow-x:hidden;
  }
  #rain{position:fixed;inset:0;z-index:0;opacity:.5;pointer-events:none;}
  .inhoud{position:relative;z-index:1;width:100%;max-width:960px;display:flex;flex-direction:column;align-items:center;}

  .logo{font-size:11px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:#ff6b5c;margin-bottom:.5rem;text-align:center;}
  h1{font-size:30px;font-weight:900;text-align:center;line-height:1.05;
     background:linear-gradient(90deg,#39ff85,#5ec6ff,#39ff85);-webkit-background-clip:text;background-clip:text;color:transparent;
     text-shadow:0 0 22px rgba(57,255,133,.25);}
  .ondertitel{font-size:14px;font-weight:700;color:#9fe9c4;margin:.25rem 0 1.1rem;text-align:center;max-width:640px;line-height:1.45;}

  .dash{display:flex;flex-wrap:wrap;justify-content:center;gap:.6rem;width:100%;max-width:760px;margin-bottom:.7rem;}
  .kpi{flex:1 1 150px;min-width:128px;background:var(--paneel);border:1.5px solid var(--paneel-rand);border-radius:14px;
       padding:.6rem .8rem;text-align:center;backdrop-filter:blur(3px);}
  .kpi .label{font-size:10.5px;font-weight:900;letter-spacing:.06em;text-transform:uppercase;color:#7fd9ab;}
  .kpi .waarde{font-size:20px;font-weight:900;color:var(--matrix);margin-top:.1rem;}
  .kpi.band .waarde{color:#cdd6d2;}
  .kpi .sub{font-size:10px;font-weight:700;color:#86a99a;margin-top:.05rem;}

  .ticker{width:100%;max-width:760px;background:rgba(4,20,13,.7);border:1.5px solid var(--paneel-rand);border-radius:12px;
          font-size:12.5px;font-weight:700;color:#bdf6d6;padding:.5rem .8rem;margin-bottom:1.1rem;text-align:center;
          min-height:2.1rem;display:flex;align-items:center;justify-content:center;gap:.4rem;}
  .ticker .knip{color:var(--matrix);}

  .verse{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;width:100%;max-width:760px;position:relative;}
  .kaart{background:var(--paneel);border:1.5px solid var(--paneel-rand);border-radius:18px;padding:.7rem .6rem .8rem;
         backdrop-filter:blur(3px);position:relative;overflow:hidden;}
  .kaart::after{content:"";position:absolute;inset:0;border-radius:18px;pointer-events:none;
                box-shadow:inset 0 0 24px rgba(57,255,133,.06);}
  .knaam{font-size:13px;font-weight:900;color:var(--licht);text-align:center;}
  .kstage{font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:.05em;color:#7fd9ab;text-align:center;
          display:flex;align-items:center;justify-content:center;gap:4px;}
  .kdot{width:8px;height:8px;border-radius:50%;display:inline-block;border:1px solid rgba(255,255,255,.4);}
  .genen{font-size:9px;font-weight:900;color:#9bd0b6;text-align:center;margin:.15rem 0 .25rem;
         display:flex;gap:6px;justify-content:center;align-items:center;flex-wrap:wrap;}
  .genen .muts{font-size:11px;letter-spacing:1px;}

  .scene{position:relative;height:128px;display:flex;align-items:flex-end;justify-content:center;margin-bottom:.4rem;}
  .bw{width:min(96px,88%);position:relative;animation:adem 3.4s ease-in-out infinite;}
  .bw svg{width:100%;height:auto;display:block;overflow:visible;transform:scale(var(--groei,1));transform-origin:50% 100%;}
  @keyframes adem{0%,100%{transform:translateY(0);}50%{transform:translateY(-4px);}}
  .bw .antenne{transform-box:view-box;transform-origin:100px 46px;animation:wieber 3.4s ease-in-out infinite;}
  .bw-baby .antenne{transform-origin:100px 8px;}
  @keyframes wieber{0%,100%{transform:rotate(-6deg);}50%{transform:rotate(6deg);}}
  .bw.act{animation:hop .5s ease-in-out;}
  @keyframes hop{0%,100%{transform:translateY(0);}45%{transform:translateY(-16px);}}
  .bw .ziek-bubbel{position:absolute;left:50%;top:-2px;transform:translateX(-50%);font-size:16px;display:none;}
  .bw.ziek .ziek-bubbel{display:block;animation:zweef-ziek 2s ease-in-out infinite;}
  @keyframes zweef-ziek{0%,100%{transform:translate(-50%,0);}50%{transform:translate(-50%,-4px);}}
  .bw.ziek svg{filter:saturate(.5) hue-rotate(35deg) brightness(.95);}
  .bw .ster{opacity:0;transition:opacity .4s;}
  .bw.vitaal .ster{opacity:1;}
  .bw .spier{opacity:0;transition:opacity .4s, transform .45s ease;transform-box:fill-box;transform-origin:center;
             transform:scale(var(--spier,1));}
  .bw.vitaal .spier{opacity:1;}
  .mut-glow{filter:drop-shadow(0 0 2.5px rgba(200,180,255,.85));}

  /* Afscheid + ei + bezoek/paart */
  .bw.weg{animation:wegzwaai 1.4s ease forwards;}
  @keyframes wegzwaai{0%{transform:translate(0,0) rotate(0);opacity:1;}
    25%{transform:translate(0,-6px) rotate(-9deg);}50%{transform:translate(0,-6px) rotate(9deg);}
    72%{transform:translate(0,-6px) rotate(-6deg);}100%{transform:translate(46px,26px) rotate(22deg);opacity:0;}}
  .ei{font-size:50px;line-height:1;animation:eiwiebel 1.05s ease-in-out infinite;filter:drop-shadow(0 0 8px rgba(127,217,255,.5));}
  @keyframes eiwiebel{0%,100%{transform:rotate(-8deg);}50%{transform:rotate(8deg);}}
  .kaart.bezoekt{box-shadow:0 0 0 2px #7fd9ff,0 0 22px rgba(127,217,255,.55);transition:box-shadow .2s;}
  .kaart.paart{box-shadow:0 0 0 2px #ff8bd0,0 0 22px rgba(255,139,208,.5);transition:box-shadow .2s;}

  /* Floaters */
  .floaters{position:absolute;inset:0;pointer-events:none;}
  .floater{position:absolute;font-weight:900;font-size:13px;left:50%;top:34px;transform:translateX(-50%);
           white-space:nowrap;animation:fl 1.1s ease-out forwards;}
  @keyframes fl{from{opacity:1;transform:translate(-50%,0);}to{opacity:0;transform:translate(-50%,-34px);}}

  .bars{display:flex;flex-direction:column;gap:3px;}
  .bar-rij{display:flex;align-items:center;gap:5px;font-size:9.5px;font-weight:900;color:#9bd9bd;}
  .bar-rij .ico{width:13px;text-align:center;}
  .bar{flex:1;height:6px;border-radius:5px;background:rgba(255,255,255,.1);overflow:hidden;}
  .bar > span{display:block;height:100%;border-radius:5px;transition:width .8s ease;}
  .b-energie>span{background:linear-gradient(90deg,#5ec6ff,#2f9fe0);}
  .b-data>span{background:linear-gradient(90deg,#3a9d94,#2f8f86);}
  .b-fit>span{background:linear-gradient(90deg,#7fd06f,#57b85f);}
  .b-geluk>span{background:linear-gradient(90deg,#ffce54,#f6a623);}

  .beam{position:absolute;height:4px;transform-origin:0 50%;pointer-events:none;z-index:6;border-radius:3px;
        background:linear-gradient(90deg,rgba(127,217,255,0),#7fd9ff,#fff,#39ff85,rgba(57,255,133,0));
        background-size:220% 100%;box-shadow:0 0 12px rgba(127,217,255,.85),0 0 22px rgba(57,255,133,.45);
        opacity:0;animation:beampuls 1.6s ease forwards, beamstroom 1.6s linear;}
  @keyframes beampuls{0%{opacity:0;}18%{opacity:.95;}75%{opacity:.85;}100%{opacity:0;}}
  @keyframes beamstroom{from{background-position:140% 0;}to{background-position:-140% 0;}}

  .live-dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--matrix);
            margin-right:5px;animation:pulse-dot 2s ease-in-out infinite;}
  @keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(.8);}}

  .uitleg{width:100%;max-width:760px;background:var(--paneel);border:1.5px solid var(--paneel-rand);border-radius:16px;
          padding:1rem 1.1rem;margin-top:1.3rem;font-size:13px;font-weight:700;color:#c7eedb;line-height:1.5;}
  .uitleg h2{font-size:15px;color:var(--matrix);margin-bottom:.4rem;}
  .uitleg p{margin-bottom:.55rem;}
  .uitleg a{color:#7fd9ff;font-weight:900;}
  .navlinks{display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;margin-top:1.4rem;}
  .navlinks a{font-size:13px;font-weight:700;color:#7fd9ab;text-decoration:none;}
  .navlinks a:hover{text-decoration:underline;}

  @media (max-width:430px){
    h1{font-size:25px;}
    .verse{gap:.45rem;}
  }
  @media (prefers-reduced-motion: reduce){
    #rain{display:none;}
    .bw,.bw .antenne,.beam,.floater,.ei,.bw.weg,.bw.act{animation:none!important;}
    .live-dot{animation:none!important;}
  }
</style>
</head>
<body>
  <canvas id="rain" aria-hidden="true"></canvas>
  <div class="inhoud">
    <p class="logo">NOLAI — Nationaal OnderwijsLab AI</p>
    <h1>Botty-verse</h1>
    <p class="ondertitel"><span class="live-dot"></span><strong>Live kijken:</strong> negen Botty's in de cloud, volledig verzorgd door de AI — dag en nacht, ook als niemand kijkt.</p>

    <div class="dash">
      <div class="kpi"><div class="label">Botty's</div><div class="waarde" id="kpi-aantal">–</div><div class="sub">in de hive</div></div>
      <div class="kpi"><div class="label">AI-zorgacties</div><div class="waarde" id="kpi-acties">–</div><div class="sub">automatisch uitgevoerd</div></div>
      <div class="kpi"><div class="label">Gem. genen</div><div class="waarde" id="kpi-genen">–</div><div class="sub">kwaliteit + efficiëntie</div></div>
      <div class="kpi"><div class="label">Draait al</div><div class="waarde" id="kpi-uptime">–</div><div class="sub">zonder mens</div></div>
      <div class="kpi band"><div class="label">Menselijke band</div><div class="waarde" id="kpi-band">0% 🤍</div><div class="sub">niemand geeft aandacht</div></div>
    </div>

    <div class="ticker" id="ticker"><span class="knip">▌</span> Verbinding maken met de hive…</div>

    <div class="verse" id="verse"></div>

    <div class="uitleg">
      <h2>🌐 Je kijkt live mee</h2>
      <p>De Hive leeft in de cloud — de AI tikt elke minuut door, ook als jij er niet bij bent. Deze pagina laadt de live stand uit de database en vernieuwt automatisch.</p>
      <p>Één meter blijft altijd leeg: de <strong>menselijke band</strong>. Die groeit alleen door <em>jouw</em> aandacht — en jij kijkt hier alleen maar.</p>
      <p>Geïnspireerd op de <a href="https://spritesmods.com/?art=tamasingularity" target="_blank" rel="noopener">Tamagotchi Singularity</a> van Sprite_tm.</p>
    </div>

    <div class="navlinks">
      <a href="botty.html">← Verzorg er zelf één</a>
      <a href="bottyverse.html">🌐 De Singularity (lokaal)</a>
    </div>
  </div>

<script type="module">
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

const SUPABASE_URL = "https://oblzouaapvdippyhxmpo.supabase.co";
const SUPABASE_ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9ibHpvdWFhcHZkaXBweWh4bXBvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4MzEyMzIsImV4cCI6MjA5NzQwNzIzMn0.dvrxesHILnLdYYrs0_p1Os7Zwi2BdShLDRj8QCkodP4";
const EI_TIJD = 4200;
const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

const supabase = createClient(SUPABASE_URL, SUPABASE_ANON);

// -------- Sprites --------
function spriteVolwassen(p){ return ''
  + '<g class="antenne"><path d="M100,46 Q96,28 109,20" fill="none" stroke="#2b2b2b" stroke-width="3" stroke-linecap="round"/>'
  +   '<circle cx="111" cy="16" r="6.5" fill="#8c9196" stroke="#2b2b2b" stroke-width="2.5"/>'
  +   '<path class="ster" d="M111,1 L112.4,5.6 117,7 112.4,8.4 111,13 109.6,8.4 105,7 109.6,5.6 Z" fill="#ffd54a" stroke="#f6a623" stroke-width="0.6"/></g>'
  + '<g class="been"><line x1="86" y1="212" x2="80" y2="236" stroke="#2b2b2b" stroke-width="4"/><ellipse cx="78" cy="239" rx="11" ry="6" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="been"><line x1="114" y1="212" x2="120" y2="236" stroke="#2b2b2b" stroke-width="4"/><ellipse cx="122" cy="239" rx="11" ry="6" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="66" y1="156" x2="36" y2="184" stroke="#2b2b2b" stroke-width="4"/><circle class="spier" cx="55" cy="166" r="7.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="34" cy="187" r="6" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="134" y1="156" x2="164" y2="184" stroke="#2b2b2b" stroke-width="4"/><circle class="spier" cx="145" cy="166" r="7.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="166" cy="187" r="6" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<rect x="68" y="184" width="64" height="30" rx="10" fill="'+p.broek+'" stroke="'+p.broekRand+'" stroke-width="3"/><line x1="100" y1="200" x2="100" y2="214" stroke="'+p.broekRand+'" stroke-width="3"/>'
  + '<rect x="66" y="140" width="68" height="52" rx="20" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/><rect x="84" y="150" width="32" height="20" rx="7" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/>'
  + '<path d="M93,124 q14,4 0,7 q-14,4 0,7" fill="none" stroke="#9aa0a4" stroke-width="4" stroke-linecap="round"/>'
  + '<g class="kop"><circle cx="52" cy="76" r="13" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="52" cy="76" r="6" fill="'+p.oogje+'"/>'
  +   '<circle cx="148" cy="76" r="13" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="148" cy="76" r="6" fill="'+p.oogje+'"/>'
  +   '<path d="M72,46 Q52,48 52,76 Q52,108 72,122 Q100,134 128,122 Q148,108 148,76 Q148,48 128,46 Q100,40 72,46 Z" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/>'
  +   '<path d="M80,64 Q100,60 120,64 Q131,66 125,79 L107,106 Q100,115 93,106 L75,79 Q69,66 80,64 Z" fill="'+p.scherm+'" stroke="'+p.schermRand+'" stroke-width="1.5"/>'
  +   '<line x1="90" y1="78" x2="90" y2="90" stroke="#1f2a28" stroke-width="4.5" stroke-linecap="round"/><line x1="110" y1="78" x2="110" y2="90" stroke="#1f2a28" stroke-width="4.5" stroke-linecap="round"/>'
  +   '<path d="M93,97 Q100,101 107,97 Q106,108 100,109 Q94,108 93,97 Z" fill="#15605a"/></g>'; }

function spriteBaby(p){ return ''
  + '<g class="antenne"><path d="M100,8 Q96,-9 109,-16" fill="none" stroke="#2b2b2b" stroke-width="3" stroke-linecap="round"/>'
  +   '<circle cx="111" cy="-20" r="6.5" fill="#8c9196" stroke="#2b2b2b" stroke-width="2.5"/>'
  +   '<path class="ster" d="M111,-29 L112.4,-24.4 117,-23 112.4,-21.6 111,-17 109.6,-21.6 105,-23 109.6,-24.4 Z" fill="#ffd54a" stroke="#f6a623" stroke-width="0.6"/></g>'
  + '<g class="been"><line x1="88" y1="204" x2="82" y2="228" stroke="#2b2b2b" stroke-width="4"/><ellipse cx="80" cy="231" rx="10" ry="5.5" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="been"><line x1="112" y1="204" x2="118" y2="228" stroke="#2b2b2b" stroke-width="4"/><ellipse cx="120" cy="231" rx="10" ry="5.5" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="66" y1="156" x2="44" y2="176" stroke="#2b2b2b" stroke-width="4"/><circle class="spier" cx="57" cy="163" r="6.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="42" cy="179" r="6" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="134" y1="156" x2="156" y2="176" stroke="#2b2b2b" stroke-width="4"/><circle class="spier" cx="143" cy="163" r="6.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="158" cy="179" r="6" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<rect x="71" y="197" width="58" height="24" rx="9" fill="'+p.broek+'" stroke="'+p.broekRand+'" stroke-width="3"/><line x1="100" y1="210" x2="100" y2="221" stroke="'+p.broekRand+'" stroke-width="3"/>'
  + '<rect x="67" y="148" width="66" height="42" rx="16" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/><rect x="83" y="157" width="34" height="18" rx="6" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/>'
  + '<path d="M93,130 q14,3 0,6 q-14,3 0,6" fill="none" stroke="#9aa0a4" stroke-width="4" stroke-linecap="round"/>'
  + '<g class="kop"><circle cx="36" cy="70" r="18" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="36" cy="70" r="8" fill="'+p.oogje+'"/>'
  +   '<circle cx="164" cy="70" r="18" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="164" cy="70" r="8" fill="'+p.oogje+'"/>'
  +   '<path d="M72,10 Q36,12 36,70 Q36,116 72,132 Q100,142 128,132 Q164,116 164,70 Q164,12 128,10 Q100,4 72,10 Z" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/>'
  +   '<path d="M76,58 Q100,52 124,58 Q136,62 130,78 L112,107 Q100,118 88,107 L70,78 Q64,62 76,58 Z" fill="'+p.scherm+'" stroke="'+p.schermRand+'" stroke-width="1.5"/>'
  +   '<line x1="90" y1="76" x2="90" y2="92" stroke="#1f2a28" stroke-width="5.5" stroke-linecap="round"/><line x1="110" y1="76" x2="110" y2="92" stroke="#1f2a28" stroke-width="5.5" stroke-linecap="round"/>'
  +   '<path d="M93,97 Q100,101 107,97 Q106,108 100,109 Q94,108 93,97 Z" fill="#15605a"/></g>'; }

function spriteTiener(p){ return ''
  + '<g class="antenne"><path d="M100,46 Q96,28 109,20" fill="none" stroke="#2b2b2b" stroke-width="3" stroke-linecap="round"/>'
  +   '<circle cx="111" cy="16" r="6.5" fill="#8c9196" stroke="#2b2b2b" stroke-width="2.5"/>'
  +   '<path class="ster" d="M111,1 L112.4,5.6 117,7 112.4,8.4 111,13 109.6,8.4 105,7 109.6,5.6 Z" fill="#ffd54a" stroke="#f6a623" stroke-width="0.6"/></g>'
  + '<g class="been"><line x1="86" y1="218" x2="76" y2="248" stroke="#2b2b2b" stroke-width="3.5"/><ellipse cx="74" cy="251" rx="11" ry="5.5" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="been"><line x1="114" y1="218" x2="124" y2="248" stroke="#2b2b2b" stroke-width="3.5"/><ellipse cx="126" cy="251" rx="11" ry="5.5" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="66" y1="155" x2="26" y2="202" stroke="#2b2b2b" stroke-width="3.5"/><circle class="spier" cx="50" cy="173" r="7.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="24" cy="205" r="5.5" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<g class="arm"><line x1="134" y1="155" x2="174" y2="202" stroke="#2b2b2b" stroke-width="3.5"/><circle class="spier" cx="150" cy="173" r="7.5" fill="'+p.broek+'" stroke="#2b2b2b" stroke-width="2"/><circle cx="176" cy="205" r="5.5" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/></g>'
  + '<rect x="67" y="193" width="66" height="30" rx="10" fill="'+p.broek+'" stroke="'+p.broekRand+'" stroke-width="3"/><line x1="100" y1="209" x2="100" y2="223" stroke="'+p.broekRand+'" stroke-width="3"/>'
  + '<rect x="65" y="136" width="70" height="62" rx="20" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/><rect x="82" y="148" width="36" height="22" rx="7" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/>'
  + '<path d="M93,124 q14,4 0,7 q-14,4 0,7" fill="none" stroke="#9aa0a4" stroke-width="4" stroke-linecap="round"/>'
  + '<g class="kop"><circle cx="52" cy="76" r="13" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="52" cy="76" r="6" fill="'+p.oogje+'"/>'
  +   '<circle cx="148" cy="76" r="13" fill="'+p.accent+'" stroke="#2b2b2b" stroke-width="2.5"/><circle cx="148" cy="76" r="6" fill="'+p.oogje+'"/>'
  +   '<path d="M72,46 Q52,48 52,76 Q52,108 72,122 Q100,134 128,122 Q148,108 148,76 Q148,48 128,46 Q100,40 72,46 Z" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="3"/>'
  +   '<path d="M80,64 Q100,60 120,64 Q131,66 125,79 L107,106 Q100,115 93,106 L75,79 Q69,66 80,64 Z" fill="'+p.scherm+'" stroke="'+p.schermRand+'" stroke-width="1.5"/>'
  +   '<line x1="90" y1="78" x2="90" y2="90" stroke="#1f2a28" stroke-width="4.5" stroke-linecap="round"/><line x1="110" y1="78" x2="110" y2="90" stroke="#1f2a28" stroke-width="4.5" stroke-linecap="round"/>'
  +   '<path d="M93,97 Q100,101 107,97 Q106,108 100,109 Q94,108 93,97 Z" fill="#15605a"/></g>'; }

const sprites    = { baby: spriteBaby, tiener: spriteTiener, volwassen: spriteVolwassen };
const groeiSchaal = { baby: 0.66, tiener: 0.92, volwassen: 1.0 };
const stageLabel = { baby: "baby", tiener: "tiener", volwassen: "volwassen" };

function mutatieSvg(id) {
  switch(id) {
    case "zonnepaneel": return '<g class="mut"><rect x="80" y="150" width="40" height="15" rx="2" fill="#16324f" stroke="#7fd9ff" stroke-width="1.5"/>'
      + '<line x1="93" y1="150" x2="93" y2="165" stroke="#7fd9ff" stroke-width="1"/><line x1="107" y1="150" x2="107" y2="165" stroke="#7fd9ff" stroke-width="1"/>'
      + '<line x1="80" y1="157.5" x2="120" y2="157.5" stroke="#7fd9ff" stroke-width="1"/></g>';
    case "wifi": return '<g class="mut mut-glow" transform="translate(150,146)"><circle cx="0" cy="6" r="2" fill="#39ff85"/>'
      + '<path d="M-6,2 A8,8 0 0 1 6,2" fill="none" stroke="#39ff85" stroke-width="2" stroke-linecap="round"/>'
      + '<path d="M-10,-2 A13,13 0 0 1 10,-2" fill="none" stroke="#39ff85" stroke-width="2" stroke-linecap="round"/></g>';
    case "antenne2": return '<g class="mut"><line x1="150" y1="150" x2="168" y2="130" stroke="#2b2b2b" stroke-width="3" stroke-linecap="round"/>'
      + '<circle cx="170" cy="127" r="5" fill="#8c9196" stroke="#2b2b2b" stroke-width="2"/></g>';
    case "oog3": return '<g class="mut"><circle cx="100" cy="158" r="6.5" fill="#fbfbf2" stroke="#2b2b2b" stroke-width="2"/><circle cx="100" cy="158" r="2.8" fill="#1f2a28"/></g>';
    case "quantum": return '<g class="mut mut-glow"><circle cx="100" cy="170" r="8" fill="#1d0f33" stroke="#c89bff" stroke-width="1.5"/>'
      + '<ellipse cx="100" cy="170" rx="8" ry="3" fill="none" stroke="#c89bff" stroke-width="1.2"/>'
      + '<ellipse cx="100" cy="170" rx="3" ry="8" fill="none" stroke="#c89bff" stroke-width="1.2"/><circle cx="100" cy="170" r="1.6" fill="#e9d6ff"/></g>';
    default: return "";
  }
}
function mutatiesSvg(list) { return (list || []).map(mutatieSvg).join(""); }
const mutatieIcoon = { zonnepaneel:"☀️", wifi:"📶", antenne2:"📡", oog3:"👁️", quantum:"⚛️" };
function mutatieIcon(id) { return mutatieIcoon[id] || "✨"; }

function spierSchaal(eff) { return (0.55 + (typeof eff === "number" ? eff : 50) / 100 * 1.0).toFixed(2); }
function gem(b) { return (b.energie + b.data + b.fit + b.geluk) / 4; }
function geneScore(b) { return (b.datakwaliteit ?? 50) + (b.efficientie ?? 50); }
function fmtDuur(ms) {
  const s = Math.floor(ms/1000), m = Math.floor(s/60), u = Math.floor(m/60), d = Math.floor(u/24);
  if (d > 0) return d+"d "+(u%24)+"u";
  if (u > 0) return u+"u "+(m%60)+"m";
  if (m > 0) return m+"m "+(s%60)+"s";
  return s+"s";
}

// -------- DOM state --------
const verse = document.getElementById("verse");
let kaartEls = [];   // [{ el, naam, stage }]
let firstOpened = null;

// -------- Animaties --------
function floater(slot, tekst, kleur) {
  if (reduce || !slot?.el) return;
  const fl = document.getElementById("fl-" + slot.naam);
  if (!fl) return;
  const f = document.createElement("div");
  f.className = "floater";
  f.textContent = tekst;
  f.style.color = kleur || "#39ff85";
  fl.appendChild(f);
  setTimeout(() => f.remove(), 1100);
}

function hopByNaam(naam) {
  if (reduce) return;
  const slot = kaartEls.find(s => s.naam === naam);
  if (!slot) return;
  const wrap = slot.el.querySelector(".bw");
  if (!wrap) return;
  wrap.classList.remove("act");
  void wrap.offsetWidth;
  wrap.classList.add("act");
  setTimeout(() => wrap.classList.remove("act"), 520);
}

function trekBeam(naamA, naamB) {
  if (reduce) return;
  const sA = kaartEls.find(s => s.naam === naamA);
  const sB = kaartEls.find(s => s.naam === naamB);
  if (!sA || !sB) return;
  const vr = verse.getBoundingClientRect();
  const ra = sA.el.getBoundingClientRect();
  const rb = sB.el.getBoundingClientRect();
  const x1 = ra.left + ra.width/2 - vr.left, y1 = ra.top + ra.height/2 - vr.top;
  const x2 = rb.left + rb.width/2 - vr.left, y2 = rb.top + rb.height/2 - vr.top;
  const dx = x2-x1, dy = y2-y1;
  const len = Math.sqrt(dx*dx + dy*dy), ang = Math.atan2(dy, dx) * 180 / Math.PI;
  const beam = document.createElement("div");
  beam.className = "beam";
  beam.style.left = x1+"px"; beam.style.top = (y1-2)+"px";
  beam.style.width = len+"px"; beam.style.transform = "rotate("+ang+"deg)";
  verse.appendChild(beam);
  setTimeout(() => beam.remove(), 1650);
}

function glowKaart(naam, klasse) {
  const slot = kaartEls.find(s => s.naam === naam);
  if (!slot) return;
  slot.el.classList.add(klasse);
  setTimeout(() => slot.el.classList.remove(klasse), 1600);
}

function afscheidByNaam(naam, cb) {
  floater(kaartEls.find(s => s.naam === naam), "👋 dag!", "#ffd54a");
  if (reduce) { cb(); return; }
  const slot = kaartEls.find(s => s.naam === naam);
  if (!slot) { cb(); return; }
  const wrap = slot.el.querySelector(".bw");
  if (!wrap) { cb(); return; }
  wrap.classList.add("weg");
  setTimeout(() => { wrap.classList.remove("weg"); cb(); }, 1450);
}

function toonEiInSlot(slot, cb) {
  const scene = slot.el.querySelector(".scene");
  if (scene) scene.innerHTML = '<div class="ei" aria-label="ei">🥚</div>';
  const kn = slot.el.querySelector(".knaam"); if (kn) kn.textContent = "Ei…";
  const ks = slot.el.querySelector(".kstage"); if (ks) ks.innerHTML = "nieuw leven · uitkomen…";
  const gn = slot.el.querySelector(".genen"); if (gn) gn.textContent = "🥚";
  setTimeout(cb, EI_TIJD);
}

// -------- Render --------
function barRij(ico, kl, meter) {
  return '<div class="bar-rij"><span class="ico">'+ico+'</span>'
       + '<span class="bar '+kl+'" data-m="'+meter+'"><span style="width:0%"></span></span></div>';
}
function genenHtml(b) {
  const dk = Math.round(b.datakwaliteit ?? 0), ef = Math.round(b.efficientie ?? 0), g = b.generatie ?? 1;
  const muts = (b.mutaties ?? []).map(mutatieIcon).join("");
  return '<span title="datakwaliteit">🧬 '+dk+'</span>'
       + '<span title="efficiëntie">💪 '+ef+'</span>'
       + '<span title="generatie">⭐ G'+g+'</span>'
       + (muts ? '<span class="muts" title="mutaties">'+muts+'</span>' : '');
}

function vulKaart(kaart, b) {
  const p = b.kleur;
  const stage = b.stage || "volwassen";
  const sprFn = sprites[stage] || spriteVolwassen;
  kaart.innerHTML =
      '<div class="knaam">'+b.naam+'</div>'
    + '<div class="kstage"><span class="kdot" style="background:'+p.broek+'"></span>'+(stageLabel[stage]||stage)+' · '+(b.paletNaam||"kleur")+'</div>'
    + '<div class="genen">'+genenHtml(b)+'</div>'
    + '<div class="scene"><div class="bw bw-'+stage+'" style="--groei:'+groeiSchaal[stage]+';--spier:'+spierSchaal(b.efficientie)+'">'
    +   '<div class="ziek-bubbel">🤒</div>'
    +   '<svg viewBox="0 0 200 250" aria-label="Botty '+b.naam+'">'+sprFn(p)+mutatiesSvg(b.mutaties)+'</svg>'
    +   '<div class="floaters" id="fl-'+b.naam+'"></div>'
    + '</div></div>'
    + '<div class="bars">'
    +   barRij("⚡","b-energie","energie")
    +   barRij("💾","b-data","data")
    +   barRij("🏃","b-fit","fit")
    +   barRij("😊","b-geluk","geluk")
    + '</div>';
  updateBarsEl(kaart, b);
}

function updateBarsEl(kaart, b) {
  const get = m => kaart.querySelector('[data-m="'+m+'"] > span');
  if (get("energie")) get("energie").style.width = b.energie + "%";
  if (get("data"))    get("data").style.width    = b.data    + "%";
  if (get("fit"))     get("fit").style.width     = b.fit     + "%";
  if (get("geluk"))   get("geluk").style.width   = b.geluk   + "%";
  const wrap = kaart.querySelector(".bw");
  if (wrap) {
    wrap.classList.toggle("vitaal", gem(b) > 65 && !b.ziek);
    wrap.classList.toggle("ziek", !!b.ziek);
  }
}

function renderState(state) {
  const bottys = state.bottys || [];
  firstOpened = state.first_opened ?? firstOpened;

  while (kaartEls.length < bottys.length) {
    const k = document.createElement("div");
    k.className = "kaart";
    verse.appendChild(k);
    kaartEls.push({ el: k, naam: null, stage: null });
  }

  bottys.forEach((b, i) => {
    const slot = kaartEls[i];
    if (slot.naam !== b.naam || slot.stage !== b.stage) {
      vulKaart(slot.el, b);
      slot.naam  = b.naam;
      slot.stage = b.stage;
    } else {
      updateBarsEl(slot.el, b);
    }
  });

  document.getElementById("kpi-aantal").textContent = bottys.length;
  document.getElementById("kpi-acties").textContent = (state.acties ?? 0).toLocaleString("nl-NL");
  const gemGenen = bottys.length
    ? Math.round(bottys.reduce((s, b) => s + geneScore(b) / 2, 0) / bottys.length)
    : "–";
  document.getElementById("kpi-genen").textContent = gemGenen;
}

function setTicker(tekst) {
  document.getElementById("ticker").innerHTML = '<span class="knip">▌</span> ' + tekst;
}

// -------- Broadcast events --------
function verwerkEvent(ev) {
  const { soort, naam, naamA, naamB, naamKind, tekst, label, kleur, animeer } = ev;

  if (tekst) setTicker(tekst);

  if (soort === "zorg") {
    if (animeer) hopByNaam(naam);
    if (label)   floater(kaartEls.find(s => s.naam === naam), label, kleur);
  }

  if (soort === "bezoek") {
    hopByNaam(naamA); hopByNaam(naamB);
    trekBeam(naamA, naamB);
    glowKaart(naamA, "bezoekt"); glowKaart(naamB, "bezoekt");
    floater(kaartEls.find(s => s.naam === naamA), "💞", "#ff8bd0");
    floater(kaartEls.find(s => s.naam === naamB), "💞", "#ff8bd0");
  }

  if (soort === "kweek-start") {
    hopByNaam(naamA); hopByNaam(naamB);
    trekBeam(naamA, naamB);
    glowKaart(naamA, "paart"); glowKaart(naamB, "paart");
    floater(kaartEls.find(s => s.naam === naamA), "💞", "#ff8bd0");
    floater(kaartEls.find(s => s.naam === naamB), "💞", "#ff8bd0");

    // Na 1.7s: afscheid ouder A, dan ei, dan wachten op hive_state UPDATE voor het kind
    setTimeout(() => {
      afscheidByNaam(naamA, () => {
        const slot = kaartEls.find(s => s.naam === naamA);
        if (slot) toonEiInSlot(slot, () => { /* kind komt via hive_state UPDATE */ });
      });
    }, 1700);
  }

  if (soort === "geboren") {
    floater(kaartEls.find(s => s.naam === naamKind), "✨ geboren", "#ffd54a");
    hopByNaam(naamKind);
  }
}

// -------- Ophalen + Realtime --------
async function laadHive() {
  const { data, error } = await supabase
    .from("hive_state")
    .select("*")
    .eq("id", "main")
    .single();

  if (error || !data) {
    setTicker("⚠️ Kon de hive niet laden. Probeer later nog eens.");
    return;
  }
  renderState(data);
  setTicker("🤖 De AI verzorgt de hive — elke minuut een nieuwe tick vanuit de cloud");
}

// Realtime: database updates
supabase
  .channel("hive-db")
  .on("postgres_changes", { event: "UPDATE", schema: "public", table: "hive_state" }, payload => {
    renderState(payload.new);
    setTicker("🔄 Hive bijgewerkt — " + new Date().toLocaleTimeString("nl-NL"));
  })
  .subscribe();

// Realtime: broadcast events van de edge function
supabase
  .channel("hive-events")
  .on("broadcast", { event: "actie" }, ({ payload }) => verwerkEvent(payload))
  .subscribe();

laadHive();

// Uptime klok
setInterval(() => {
  if (firstOpened) {
    document.getElementById("kpi-uptime").textContent = fmtDuur(Date.now() - firstOpened);
  }
}, 1000);

// -------- Matrix-regen --------
(function rain() {
  if (reduce) return;
  const cv = document.getElementById("rain"), ctx = cv.getContext("2d");
  const tekens = "01ボッティBOTTY0110アイデータＡＩ".split("");
  const kolB = 15;
  let druppels = [];
  function size() {
    cv.width = window.innerWidth; cv.height = window.innerHeight;
    const n = Math.floor(cv.width / kolB);
    druppels = [];
    for (let i = 0; i < n; i++) druppels[i] = Math.random() * cv.height / kolB;
  }
  size();
  window.addEventListener("resize", size);
  function frame() {
    ctx.fillStyle = "rgba(4,20,13,0.10)";
    ctx.fillRect(0, 0, cv.width, cv.height);
    ctx.font = (kolB - 2) + "px monospace";
    for (let i = 0; i < druppels.length; i++) {
      const t = tekens[Math.floor(Math.random() * tekens.length)];
      ctx.fillStyle = Math.random() < 0.04 ? "#cffce0" : "#1f9d5a";
      ctx.fillText(t, i * kolB, druppels[i] * kolB);
      if (druppels[i] * kolB > cv.height && Math.random() > 0.975) druppels[i] = 0;
      druppels[i]++;
    }
    requestAnimationFrame(frame);
  }
  frame();
})();
</script>
</body>
</html>
